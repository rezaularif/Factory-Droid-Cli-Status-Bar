{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/lifecycle.js\" start", "timeout": 10 }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/lifecycle.js\" end", "timeout": 10 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/update.js\" prompt", "timeout": 10 }] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/update.js\" pre", "timeout": 10 }] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/update.js\" post", "timeout": 10 }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/update.js\" notify", "timeout": 10 }] }
    ],
    "PermissionRequest": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/update.js\" permreq", "timeout": 10 }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/update.js\" stop", "timeout": 10 }] }
    ],
    "SubagentStop": [
      { "hooks": [{ "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/update.js\" stop", "timeout": 10 }] }
    ]
  }
}
